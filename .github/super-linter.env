# Super-Linter Shared Configuration
# Single source of truth for linter selection and non-path settings.
# Consumed by CI (.github/workflows/super-linter.yml).
#
# Adapted from kloehnwars-homelab (standalone-consumer model): homelab-only
# selections dropped (Ansible - no automation/ tree here; Checkov - no IaC;
# JSCPD - no .jscpd.json config and imported upstream test suites would trip
# duplication thresholds).
#
# Keys MUST be alphabetically sorted (dotenv-linter enforces this).

# --- Linter config paths (relative, resolved by Super-Linter) ---
LINTER_RULES_PATH=.github/linters
MARKDOWN_CONFIG_FILE=.markdownlint.yml

# --- Linter selection (alphabetical) ---
VALIDATE_BASH=true
VALIDATE_BASH_EXEC=true
VALIDATE_EDITORCONFIG=true
VALIDATE_ENV=true
VALIDATE_GITHUB_ACTIONS=true
VALIDATE_GITLEAKS=true
VALIDATE_JSON=true
VALIDATE_JSONC=true
VALIDATE_MARKDOWN=true
VALIDATE_POWERSHELL=true
VALIDATE_PYTHON_RUFF=true
VALIDATE_PYTHON_RUFF_FORMAT=true
VALIDATE_SHELL_SHFMT=true
VALIDATE_YAML=true
