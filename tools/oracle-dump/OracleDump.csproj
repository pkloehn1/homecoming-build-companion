<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <SupportedOSPlatformVersion>10.0.19041.0</SupportedOSPlatformVersion>
    <OutputType>Exe</OutputType>
    <UseWindowsForms>true</UseWindowsForms>
    <Platforms>x64</Platforms>
    <PlatformTarget>x64</PlatformTarget>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <LangVersion>12.0</LangVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>OracleDump</RootNamespace>
    <AssemblyName>OracleDump</AssemblyName>
    <!-- Test-only harness: references the MidsReborn fork checked out as a sibling of
         this repo. The fork's Core namespace holds the authoritative build math; this
         harness loads the Homecoming DB headless and dumps JSON the Python port's
         golden fixtures are baselined against. -->
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\..\MidsReborn\MidsReborn\MidsReborn.csproj" />
  </ItemGroup>
</Project>
